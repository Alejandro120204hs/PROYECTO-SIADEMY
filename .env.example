# ============================================================
# Siademy — plantilla de variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# Este archivo SÍ se versiona (sin valores sensibles).
# ============================================================

DB_HOST=localhost
DB_NAME=siademy
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ============================================================
# Wompi — Pasarela de pagos
# ============================================================
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_KEY=
WOMPI_INTEGRITY_KEY=
